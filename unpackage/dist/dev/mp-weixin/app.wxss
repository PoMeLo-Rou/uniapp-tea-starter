.loading-mask.data-v-8706b652 {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(0, 0, 0, 0.4);
}
.loading-mask.mask-blur.data-v-8706b652 {
  -webkit-backdrop-filter: blur(8rpx);
          backdrop-filter: blur(8rpx);
}
.loading-box.data-v-8706b652 {
  min-width: 200rpx;
  padding: 40rpx 48rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.12);
}
.logo-wrap.data-v-8706b652 {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 24rpx;
}
.logo-img.data-v-8706b652 {
  width: 100%;
  height: 100%;
}
.logo-img.logo-spin.data-v-8706b652 {
  animation: spin-8706b652 1s linear infinite;
}

/* 内置：转圈 */
.spinner.data-v-8706b652 {
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 24rpx;
  border: 6rpx solid #e5e5e5;
  border-top-color: #023993;
  border-radius: 50%;
  animation: spin-8706b652 0.8s linear infinite;
}

/* 内置：三点跳动 */
.dots.data-v-8706b652 {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.dots .dot.data-v-8706b652 {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #023993;
  animation: bounce-8706b652 0.6s ease-in-out infinite;
}
.dots .dot.data-v-8706b652:nth-child(2) {
  animation-delay: 0.1s;
}
.dots .dot.data-v-8706b652:nth-child(3) {
  animation-delay: 0.2s;
}

/* 内置：茶杯热气 */
.tea-steam.data-v-8706b652 {
  position: relative;
  margin-bottom: 24rpx;
}
.tea-steam .cup.data-v-8706b652 {
  font-size: 64rpx;
  line-height: 1;
}
.tea-steam .steam.data-v-8706b652 {
  position: absolute;
  bottom: 56rpx;
  width: 8rpx;
  height: 24rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.15), transparent);
  border-radius: 4rpx;
  animation: steam-8706b652 1.2s ease-in-out infinite;
}
.tea-steam .s1.data-v-8706b652 {
  left: 50%;
  transform: translateX(-120%);
  animation-delay: 0s;
}
.tea-steam .s2.data-v-8706b652 {
  left: 50%;
  transform: translateX(-50%);
  animation-delay: 0.2s;
}
.tea-steam .s3.data-v-8706b652 {
  left: 50%;
  transform: translateX(20%);
  animation-delay: 0.4s;
}
.loading-title.data-v-8706b652 {
  font-size: 28rpx;
  color: #666;
}
@keyframes spin-8706b652 {
to {
    transform: rotate(360deg);
}
}
@keyframes bounce-8706b652 {
0%, 100% {
    transform: translateY(0);
}
50% {
    transform: translateY(-12rpx);
}
}
@keyframes steam-8706b652 {
0%, 100% {
    opacity: 0.3;
    transform: translateY(0) scaleY(1);
}
50% {
    opacity: 0.8;
    transform: translateY(-8rpx) scaleY(1.2);
}
}


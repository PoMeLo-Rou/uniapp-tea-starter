/* 弹窗整体置于 tabBar 之上（小程序 tabBar 层级约 9999） */
.product-detail-popup-root.data-v-6255fdd0 {
  position: relative;
  z-index: 10001;
}
.data-v-6255fdd0 .uni-popup {
  z-index: 10001 !important;
}
/* 统一容器：避免小程序与 H5 宽度/盒模型不一致导致裁切 */
.spec-container.data-v-6255fdd0 {
  box-sizing: border-box;
  width: 100%;
  padding: 30rpx;
  padding-bottom: calc(30rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
}
.spec-header.data-v-6255fdd0 {
  margin-bottom: 30rpx;
}
.spec-header .spec-title.data-v-6255fdd0 {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.spec-group.data-v-6255fdd0 {
  margin-bottom: 30rpx;
  /* 小程序不用负 margin，避免整块不渲染；用右/下 margin 做间距 */
}
.spec-group .label.data-v-6255fdd0 {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}
.spec-group .tags.data-v-6255fdd0 {
  display: flex;
  flex-wrap: wrap;
  width: 100%;
  min-height: 80rpx;
}
.spec-group .spec-tag.data-v-6255fdd0 {
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  padding: 12rpx 24rpx;
  min-height: 56rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 8rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}
.spec-group .spec-tag text.data-v-6255fdd0 {
  font-size: 26rpx;
  color: inherit;
}
.spec-group .spec-tag.active.data-v-6255fdd0 {
  background: #023993;
  color: #fff;
}
.spec-group .spec-tag.active text.data-v-6255fdd0 {
  color: #fff;
}
/* 小程序 button 默认有边框、padding，需彻底重置以与 H5 一致 */
.confirm-btn.data-v-6255fdd0 {
  display: block;
  margin-top: 40rpx;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #023993;
  color: #fff;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: none;
}
.confirm-btn.data-v-6255fdd0::after {
  border: none;
}
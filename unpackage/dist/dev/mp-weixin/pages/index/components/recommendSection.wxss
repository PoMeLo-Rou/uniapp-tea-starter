.recommend-section.data-v-8b79574f {
  padding: 20rpx;
}
.recommend-section .section-header.data-v-8b79574f {
  margin-bottom: 20rpx;
}
.recommend-section .section-header .title.data-v-8b79574f {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.recommend-section .section-header .subtitle.data-v-8b79574f {
  font-size: 24rpx;
  color: #999;
  margin-left: 15rpx;
}
.recommend-section .recommend-scroll.data-v-8b79574f {
  white-space: nowrap;

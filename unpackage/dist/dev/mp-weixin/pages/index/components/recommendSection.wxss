}
.recommend-section .recommend-scroll.data-v-8b79574f ::-webkit-scrollbar {
  display: none;
}
.recommend-section .recommend-scroll.data-v-8b79574f ::-webkit-scrollbar-thumb {
  display: none;
}
.recommend-section .recommend-scroll.data-v-8b79574f ::-webkit-scrollbar-track {
  display: none;
}
.recommend-section .recommend-scroll .recommend-item.data-v-8b79574f {
  display: inline-block;
  width: 240rpx;
  margin-right: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 15rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}
.recommend-section .recommend-scroll .recommend-item .prod-img.data-v-8b79574f {
  width: 100%;
  height: 200rpx;
  border-radius: 8rpx;
}

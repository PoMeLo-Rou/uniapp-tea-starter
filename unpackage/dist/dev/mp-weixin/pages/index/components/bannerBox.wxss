.banner-box.data-v-8e086060 {
  /* 移除原本的 padding，或者确保指示器能撑满宽度 */
  padding: 30rpx 30rpx 0;
  background-color: transparent;
}
.banner-box .banner-swiper.data-v-8e086060 {
  height: 350rpx;
  border-radius: 20rpx;
  overflow: hidden;
  transform: translateY(0);
  box-shadow: 0 10rpx 20rpx rgba(0, 0, 0, 0.08);
}
.banner-box .banner-swiper .banner-img.data-v-8e086060 {
  width: 100%;
  height: 100%;
}
.banner-box .indicator-wrapper.data-v-8e086060 {
  width: 100%;
  margin-top: 24rpx;
}
.banner-box .indicator-track.data-v-8e086060 {
  position: relative;
  width: 100%;
  height: 4rpx;
  background-color: #f0f0f0;
}
.banner-box .indicator-active.data-v-8e086060 {
  position: absolute;
  top: 0;
  left: 0;
  height: 100%;
  background-color: #023993;
  /* 动画过渡 */
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.container {
  min-height: 100vh;
  background-color: #f8f8f8;
  padding-bottom: 150rpx;
}
.recommend-section {
  padding: 20rpx;
}
.recommend-section .section-header {
  margin-bottom: 20rpx;
}
.recommend-section .section-header .title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.recommend-section .section-header .subtitle {
  font-size: 24rpx;
  color: #999;
  margin-left: 15rpx;
}
.recommend-section .recommend-scroll {
  white-space: nowrap;
}
.recommend-section .recommend-scroll .recommend-item {
  display: inline-block;
  width: 240rpx;
  margin-right: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 15rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}
.recommend-section .recommend-scroll .recommend-item .prod-img {
  width: 100%;
  height: 200rpx;
  border-radius: 8rpx;
}
.recommend-section .recommend-scroll .recommend-item .prod-name {
  font-size: 26rpx;
  display: block;
  margin: 10rpx 0;
}
.recommend-section .recommend-scroll .recommend-item .prod-price {
  color: #023993;
  font-weight: bold;
}
.recommend-section .recommend-scroll .recommend-item .add-btn {
  float: right;
  width: 48rpx;
  height: 48rpx;
  min-width: 48rpx;
  line-height: 48rpx;
  background: #023993;
  color: #fff;
  border-radius: 50%;
  padding: 0;
  border: none;
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
}
.recommend-section .recommend-scroll .recommend-item .add-btn::after {
  border: none;
}
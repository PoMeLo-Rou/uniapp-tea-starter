.container {
  min-height: 100vh;
  background-color: #f8f8f8;
  position: relative;
}
.banner-box {
  position: relative;
  z-index: 1;
  /* 等分的小灰线段（覆盖在灰线之上，方便看出分段） */
  /* 蓝色活动条，带左右滑动过渡 */
}
.banner-box .banner-swiper {
  height: 350rpx;
  border-radius: 20rpx 20rpx 0 0;
  overflow: hidden;
}
.banner-box .banner-swiper .banner-img {
  width: 100%;
  height: 100%;
}
.banner-box .banner-indicator-line {
  position: relative;
  margin: 16rpx 0 0;
  height: 4rpx;
}
.banner-box .banner-indicator-line .line-bg {
  position: absolute;
  left: 0;
  right: 0;
  top: 1rpx;
  height: 2rpx;
  background-color: #e5e5e5;
  border-radius: 2rpx;
}
.banner-box .banner-indicator-line .line-segments {
  position: absolute;
  left: 0;
  right: 0;
  top: 1rpx;
  height: 2rpx;
  display: flex;
}
.banner-box .banner-indicator-line .line-segment {
  height: 2rpx;
  background-color: transparent;
  border-radius: 2rpx;
}
.banner-box .banner-indicator-line .line-active {
  position: absolute;
  top: 1rpx;
  height: 2rpx;
  background-color: #023993;
  border-radius: 2rpx;
  transition: left 0.25s ease;
}
.member-bar {
  margin: 30rpx;
  background-color: #fff;
  padding: 30rpx;
  border-radius: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: relative;
  z-index: 1;
}
.member-bar .welcome {
  font-size: 32rpx;
  font-weight: bold;
}
.member-bar .level {
  font-size: 24rpx;
  color: #666;
  margin-top: 10rpx;
}
.member-bar .level .icon {
  margin-right: 6rpx;
}
.member-bar .points {
  text-align: right;
}
.member-bar .points .num {
  font-size: 40rpx;
  font-weight: bold;
  color: #023993;
  display: block;
}
.member-bar .points .label {
  font-size: 22rpx;
  color: #999;
}
.main-actions {
  margin: 0 30rpx;
  background-color: #fff;
  border-radius: 20rpx;
  display: flex;
  padding: 40rpx 0;
  align-items: center;
}
.main-actions .action-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.main-actions .action-card .action-icon {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 20rpx;
}
.main-actions .action-card .action-text {
  text-align: center;
}
.main-actions .action-card .action-text .title {
  font-size: 34rpx;
  font-weight: bold;
  display: block;
}
.main-actions .action-card .action-text .desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}
.main-actions .divider {
  width: 2rpx;
  height: 120rpx;
  background-color: #eee;
}
.featured-section {
  padding: 40rpx 30rpx;
}
.featured-section .section-header {
  margin-bottom: 20rpx;
}
.featured-section .section-header .section-title {
  font-size: 32rpx;
  font-weight: bold;
}
.featured-section .featured-list {
  overflow: scroll;
  scrollbar-width: none;
  -ms-overflow-style: none;
  white-space: nowrap;
}
.featured-section .featured-list ::-webkit-scrollbar {
  display: none;
}
.featured-section .featured-list .featured-item {
  display: inline-block;
  width: 260rpx;
  margin-right: 20rpx;
  background-color: #fff;
  border-radius: 15rpx;
  padding: 15rpx;
}
.featured-section .featured-list .featured-item .featured-img {
  width: 100%;
  height: 200rpx;
  border-radius: 10rpx;
  background-color: #f0f0f0;
}
.featured-section .featured-list .featured-item .name {
  font-size: 26rpx;
  margin-top: 15rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
}
.featured-section .featured-list .featured-item .price {
  font-size: 26rpx;
  color: #023993;
  font-weight: bold;
  margin-top: 10rpx;
  display: block;
}
.card-wrap {
  margin: 0 30rpx 40rpx;
}